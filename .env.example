# NodeScope — Environment Configuration
#
# Copy this file to .env and set values for your environment.
# .env is gitignored and must never be committed.
#
# For Docker quickstart, the defaults below work out of the box.
# Inside Compose, services override RPC/ZMQ URLs to use Docker service names.
# For non-Docker local development, keep the 127.0.0.1 values below.

# ---------------------------------------------------------------------------
# Bitcoin Core RPC
# ---------------------------------------------------------------------------
BITCOIN_RPC_URL=http://127.0.0.1:18443
BITCOIN_RPC_USER=nodescope
BITCOIN_RPC_PASSWORD=nodescope

# ---------------------------------------------------------------------------
# ZMQ endpoints (used by monitor.py)
# ---------------------------------------------------------------------------
ZMQ_RAWBLOCK_URL=tcp://127.0.0.1:28332
ZMQ_RAWTX_URL=tcp://127.0.0.1:28333

# ---------------------------------------------------------------------------
# Log storage
# ---------------------------------------------------------------------------
# Directory where NDJSON logs are written. Defaults to logs/ if not set.
NODESCOPE_LOG_DIR=logs

# ---------------------------------------------------------------------------
# Local development servers (host-side)
# ---------------------------------------------------------------------------
API_HOST=127.0.0.1
API_PORT=8000
FRONTEND_PORT=5173

# Vite proxy target used by the frontend dev server outside Docker.
# Docker Compose overrides this to http://nodescope-api:8000.
VITE_API_PROXY_TARGET=http://127.0.0.1:8000

# ---------------------------------------------------------------------------
# Optional API key protection
# ---------------------------------------------------------------------------
# When NODESCOPE_REQUIRE_API_KEY is true, all state-changing endpoints (POST/PUT)
# require the X-NodeScope-API-Key header. Read-only endpoints remain unprotected.
# Default is false so Docker quickstart and local demos work without configuration.
# Never commit a real key value — set it only in your local .env file.
NODESCOPE_REQUIRE_API_KEY=false
NODESCOPE_API_KEY=

# ---------------------------------------------------------------------------
# Docker host ports
# ---------------------------------------------------------------------------
# Keep the defaults for a clean machine. If local bitcoind or local API are
# already using these ports, override only the HOST_* values in .env.
HOST_BITCOIN_RPC_PORT=18443
HOST_ZMQ_RAWBLOCK_PORT=28332
HOST_ZMQ_RAWTX_PORT=28333
HOST_API_PORT=8000
HOST_FRONTEND_PORT=5173
