# NodeScope — Environment Configuration
#
# Copy this file to .env and set values for your environment.
# .env is gitignored and must never be committed.
#
# For local regtest development, the defaults below work out of the box.

# ---------------------------------------------------------------------------
# Bitcoin Core RPC
# ---------------------------------------------------------------------------
BITCOIN_RPC_URL=http://127.0.0.1:18443
BITCOIN_RPC_USER=nodescope
BITCOIN_RPC_PASSWORD=nodescope

# ---------------------------------------------------------------------------
# ZMQ endpoints (used by monitor.py)
# ---------------------------------------------------------------------------
ZMQ_RAWBLOCK_URL=tcp://127.0.0.1:28332
ZMQ_RAWTX_URL=tcp://127.0.0.1:28333

# ---------------------------------------------------------------------------
# Log storage
# ---------------------------------------------------------------------------
# Directory where NDJSON logs are written. Defaults to ./logs/ if not set.
NODESCOPE_LOG_DIR=./logs
