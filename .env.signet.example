# NodeScope — Signet Observer Mode (Phase 2)
# Copy to .env and update credentials before use.
# Never commit .env with real credentials.

# --- Bitcoin Core Signet RPC ---
# Default signet RPC port is 38332
BITCOIN_RPC_URL=http://127.0.0.1:38332
BITCOIN_RPC_USER=nodescope
BITCOIN_RPC_PASSWORD=nodescope

# --- ZMQ Endpoints ---
ZMQ_RAWBLOCK_URL=tcp://127.0.0.1:28332
ZMQ_RAWTX_URL=tcp://127.0.0.1:28333

# --- Log Storage ---
NODESCOPE_LOG_DIR=logs/

# --- API Server (local) ---
API_HOST=127.0.0.1
API_PORT=8000

# --- Frontend Dev Server ---
FRONTEND_PORT=5173

# --- Docker Host Port Overrides (optional) ---
# HOST_BITCOIN_RPC_PORT=38332
# HOST_ZMQ_RAWBLOCK_PORT=28332
# HOST_ZMQ_RAWTX_PORT=28333
# HOST_API_PORT=8000
# HOST_FRONTEND_PORT=5173
