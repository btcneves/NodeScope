.env
.env.local
.env.*.local

# Obsidian editor state
**/.obsidian/

# Local notes, reports and vault
notes/
reports/
.local-run/

# System
.DS_Store
Thumbs.db

# Backups
*.bak
*.orig

# Editor
.idea/
.vscode/
*.swp
*.swo

# Tool caches
.ruff_cache/
.pytest_cache/
htmlcov/

# Local-only workspace files
.local/
